# Twilio Credentials - Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# SMS (fallback) - Your Twilio phone number
TWILIO_PHONE=+1234567890

# WhatsApp - Sandbox setup
# 1. Go to https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 2. Join the Sandbox (send "join <code>" to +1 415 523 8886)
# 3. Create a Verification Codes template in Content Template Builder
#    Template: "Your {{1}} code is {{2}}"  -> ContentVariables: 1=App name, 2=OTP
# 4. Copy the Content SID (starts with HX) and set below
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_VERIFICATION_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Country code for phone numbers (e.g. 91 for India)
COUNTRY_CODE=91

# Server port
PORT=3000
